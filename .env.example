# Neon Postgres — pooled connection string (runtime, used by the app via
# the @prisma/adapter-neon driver adapter). Get this from your Neon project
# dashboard -> Connect -> "Pooled connection".
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Neon Postgres — direct (unpooled) connection string, used only by
# `prisma migrate` / `prisma db seed`. Same as above but WITHOUT "-pooler"
# in the hostname. Get this from Neon -> Connect -> "Direct connection".
DIRECT_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# Single admin user, seeded by prisma/seed.ts.
ADMIN_EMAIL="you@example.com"
# bcrypt hash of your password — NEVER put a plaintext password here.
# Generate it with: node -e "console.log(require('bcryptjs').hashSync(process.argv[1], 12))" "your-password-here"
# If the hash starts with $2b$ or similar, escape every "$" as "\$" so
# Next.js's built-in env-var expansion doesn't corrupt it (see README).
ADMIN_PASSWORD_HASH="\$2b\$12\$replace-with-your-generated-hash"

# Auth.js v5 secret — generate with: npx auth secret  (or: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-random-32-byte-base64-string"
